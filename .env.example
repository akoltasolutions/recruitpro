# ════════════════════════════════════════════════════════
#  RECRUITPRO — Environment Variables
#  Copy this file to .env on your server and fill in values
# ════════════════════════════════════════════════════════

# Database (SQLite)
DATABASE_URL="file:./db/custom.db"

# Auth token secret (CHANGE THIS to a random long string!)
TOKEN_SECRET="recruitpro-production-secret-key-change-this"

# App environment
NODE_ENV="production"

# Server port
PORT=3000

# Server host (0.0.0.0 = accepts connections from all IPs)
HOSTNAME="0.0.0.0"

# Allow database seeding (set to "true" only on first setup)
ALLOW_SEED="false"
