generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== MULTI-TENANT MODELS ====================

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String
  description     String?
  type            String   @default("CUSTOM") // FREE, STARTER, BUSINESS, ENTERPRISE, CUSTOM
  monthlyPrice    Float    @default(0)
  yearlyPrice     Float    @default(0)
  maxUsers        Int      @default(10)
  maxNumbers      Int      @default(5000)
  dailyUploadLimit Int     @default(500)
  maxProjects     Int      @default(5)
  maxDepartments  Int     @default(10)
  isActive        Boolean  @default(true)
  isDefault       Boolean  @default(false)
  features        String   @default("[]") // JSON array of feature strings
  trialDays         Int      @default(0)           // number of trial days
  monthlyCallLimit  Int      @default(0)           // max calls per month, -1 = unlimited
  dailyCallLimit    Int      @default(0)           // max calls per day, -1 = unlimited
  storageLimit      Int      @default(0)           // MB, -1 = unlimited
  isUnlimited       Boolean  @default(false)       // master unlimited toggle
  featureAccess     String   @default("{}")        // JSON: granular feature toggles
  sortOrder         Int      @default(0)           // display order
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizations Organization[]
}

model Organization {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  email                 String
  phone                 String?
  address               String?
  logo                  String?
  isActive              Boolean  @default(true)
  maxUsers              Int      @default(10)
  maxNumbers            Int      @default(5000)
  dailyUploadLimit      Int      @default(500)
  subscriptionPlanId    String?
  subscriptionStatus    String   @default("TRIAL") // TRIAL, ACTIVE, SUSPENDED, CANCELLED
  trialEndsAt           DateTime?
  subscriptionStartsAt  DateTime?
  subscriptionEndsAt    DateTime?
  customMonthlyPrice    Float?
  customYearlyPrice     Float?
  customNotes           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  plan                  SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  users                 User[]
  departments           Department[]
  projects              CallingProject[]
  callLists             CallList[]
  dispositions          Disposition[]
  candidates            Candidate[]
  callRecords           CallRecord[]
  clients               Client[]
  messageTemplates      MessageTemplate[]
  announcements         Announcement[]
  activityLogs          ActivityLog[]
  callListAssignments   CallListAssignment[]
  whatsappMessages      WhatsAppMessage[]
  dynamicFields         DynamicField[]
  customDispositions    CustomDisposition[]
  customDesignations    CustomDesignation[]
  invitations           Invitation[]
  shiftAssignments      ShiftAssignment[]
  pipelineNotes          PipelineNote[]
}

model Department {
  id             String   @id @default(cuid())
  name           String
  description    String?
  organizationId String
  headUserId     String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]
  projects       CallingProject[]
}

model CallingProject {
  id             String   @id @default(cuid())
  name           String
  description    String?
  organizationId String
  departmentId   String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department     Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  callLists      CallList[]
  dynamicFields  DynamicField[]
  customDispositions CustomDisposition[]
  dispositions       Disposition[]
}

model DynamicField {
  id             String   @id @default(cuid())
  name           String   // field key (e.g. "alternate_phone")
  label          String   // display label (e.g. "Alternate Number")
  fieldType      String   @default("TEXT") // TEXT, NUMBER, DATE, EMAIL, PHONE, SELECT, MULTI_SELECT, BOOLEAN, TEXTAREA, URL
  options        String?  // JSON array for SELECT type: ["Option A", "Option B"]
  isRequired     Boolean  @default(false)
  organizationId String
  projectId      String?  // null = org-level field, set = project-level
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        CallingProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model CustomDisposition {
  id             String   @id @default(cuid())
  name           String
  color          String   @default("#6B7280")
  isPositive     Boolean  @default(false)
  organizationId String
  projectId      String?  // null = org-level, set = project-level
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        CallingProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model CustomDesignation {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]
}

model Invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String   @default("USER") // ORG_ADMIN, USER
  designation    String?
  departmentId   String?
  token          String   @unique
  status         String   @default("PENDING") // PENDING, ACCEPTED, EXPIRED, REVOKED
  invitedBy      String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

// ==================== SHIFT MANAGEMENT ====================

model ShiftAssignment {
  id                  String   @id @default(cuid())
  userId              String   @unique
  organizationId      String?
  shiftStartTime      String   // "09:00" (HH:mm, 24h format)
  shiftEndTime        String   // "18:00"
  breakAllowedTime    String?  // "00:30" (30 min break allowed)
  workingHoursTotal   String?  // "09:00" (9 hours total)
  weeklyOff           String?  // "SUNDAY" or "SATURDAY,SUNDAY"
  allowOutsideShift   Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization        Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ==================== EXISTING MODELS (MODIFIED) ====================

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  password            String
  name                String
  phone               String?
  role                String   @default("USER") // SUPER_ADMIN, ORG_ADMIN, USER
  isActive            Boolean  @default(true)
  approvalStatus      String   @default("APPROVED") // PENDING, APPROVED, REJECTED, DELETED
  avatarUrl           String?
  // Organization membership
  organizationId      String?
  departmentId        String?
  designationId       String?
  designation         String?  // free-text fallback for custom designations
  // Permission toggles
  callModeOn          Boolean  @default(true)
  whatsappAccess      Boolean  @default(true)
  uploadPermission    Boolean  @default(false)
  createListPermission Boolean @default(false)
  // Password recovery fields
  resetToken          String?
  resetTokenExpires   DateTime?
  otpCode             String?
  otpExpires          DateTime?
  // MFA fields
  mfaSecret           String?
  mfaEnabled          Boolean  @default(false)
  mfaVerified         Boolean  @default(false)
  mfaBackupCodes      String?  // JSON array of backup codes
  // Account security fields
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  tokenVersion        Int      @default(0)
  passwordChangedAt   DateTime?
  // Login tracking
  lastLoginAt         DateTime?
  lastLoginIp         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  organization        Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department          Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designationRel      CustomDesignation? @relation(fields: [designationId], references: [id], onDelete: SetNull)
  assignedCallLists   CallListAssignment[]
  callRecords         CallRecord[]
  whatsappMessages    WhatsAppMessage[]
  activityLogs        ActivityLog[]
  shiftAssignment     ShiftAssignment?
  pipelineNotes        PipelineNote[]
  passwordHistories    PasswordHistory[]
  sessions            Session[]

  @@index([organizationId, role])
  @@index([organizationId, isActive])
  @@index([phone])
}

model Client {
  id             String   @id @default(cuid())
  name           String   @unique
  organizationId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  callRecords    CallRecord[]

  @@index([organizationId])
}

model Disposition {
  id             String   @id @default(cuid())
  heading        String
  type           String   // SHORTLISTED, CONNECTED, NOT_CONNECTED, NOT_INTERESTED
  isActive       Boolean  @default(true)
  organizationId String?
  projectId      String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        CallingProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  callRecords    CallRecord[]

  @@index([organizationId])
}

model CallList {
  id               String    @id @default(cuid())
  name             String
  description      String?
  source           String    @default("MANUAL") // MANUAL, CSV, XLSX, COPY_PASTE, GOOGLE_SHEETS
  createdBy        String
  organizationId   String?
  projectId        String?
  googleSheetsUrl  String?
  googleSheetGid   String?
  syncInterval     Int       @default(0) // minutes, 0 = disabled
  lastSyncedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization     Organization?         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project          CallingProject?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  candidates       Candidate[]
  assignments       CallListAssignment[]

  @@index([organizationId])
  @@index([projectId])
}

model Candidate {
  id             String   @id @default(cuid())
  callListId     String
  organizationId String?
  name           String
  phone          String
  email          String?
  role           String?
  location       String?
  company        String?
  notes          String?
  status         String   @default("PENDING") // PENDING, DONE, SCHEDULED, SKIPPED
  pipelineStage  String   @default("NEW") // NEW, SHORTLISTED, FOLLOW_UP, INTERVIEWED, JOINED, BACKOUT
  followUpDate   DateTime?
  interviewDate  DateTime?
  joinedDate     DateTime?
  backoutReason  String?
  remarks        String?
  // Dynamic custom field data stored as JSON
  dynamicData    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  callList       CallList        @relation(fields: [callListId], references: [id], onDelete: Cascade)
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  callRecords    CallRecord[]
  pipelineNotes  PipelineNote[]

  @@index([callListId, createdAt])
  @@index([organizationId, pipelineStage])
}

model CallListAssignment {
  id             String   @id @default(cuid())
  callListId     String
  recruiterId    String
  organizationId String?
  assignedAt     DateTime @default(now())

  callList       CallList     @relation(fields: [callListId], references: [id], onDelete: Cascade)
  recruiter      User         @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([recruiterId])
  @@index([callListId])
}

model CallRecord {
  id             String   @id @default(cuid())
  candidateId    String
  recruiterId     String
  dispositionId  String?
  clientId       String?
  organizationId String?
  notes          String?
  callDuration   Int      @default(0)
  callStartedAt  DateTime? // Timestamp when recruiter clicked Call button
  callStatus     String   @default("COMPLETED") // COMPLETED, FAILED, SKIPPED, SCHEDULED
  scheduledAt    DateTime?
  f2fInterviewDate DateTime?
  customClientName String?
  calledAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  candidate      Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  recruiter      User         @relation(fields: [recruiterId], references: [id])
  disposition    Disposition? @relation(fields: [dispositionId], references: [id])
  client         Client?      @relation(fields: [clientId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, calledAt])
  @@index([recruiterId, calledAt])
  @@index([candidateId])
  @@index([dispositionId])
  @@index([callStartedAt])
}

model MessageTemplate {
  id             String   @id @default(cuid())
  name           String
  type           String   // NOT_ANSWERED, SHORTLISTED, CUSTOM
  channel        String   @default("ALL") // SMS, WHATSAPP, ALL
  content        String   // supports {{candidate_name}}, {{recruiter_name}}, {{role}}, {{location}}
  isActive       Boolean  @default(true)
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model WhatsAppMessage {
  id             String   @id @default(cuid())
  recruiterId    String
  candidateId    String?
  phone          String
  message        String
  status         String   @default("SENT") // SENT, FAILED, PENDING
  sentAt         DateTime @default(now())
  organizationId String?

  recruiter      User         @relation(fields: [recruiterId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([recruiterId])
  @@index([organizationId])
}

model Announcement {
  id             String   @id @default(cuid())
  title          String
  content        String
  isActive       Boolean  @default(true)
  createdBy      String
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model ActivityLog {
  id             String   @id @default(cuid())
  userId         String
  action         String   // LOGIN, LOGOUT, IDLE, ACTIVE, BREAK_START, BREAK_END, ON_CALL, CALL_END
  status         String   @default("ACTIVE") // ACTIVE, IDLE, OFFLINE, ON_CALL, ON_BREAK
  metadata       String?  // JSON string
  ipAddress      String?
  userAgent      String?
  organizationId String?
  createdAt      DateTime @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
}

// ==================== PIPELINE NOTES (AUDIT TRAIL) ====================

model PipelineNote {
  id             String   @id @default(cuid())
  candidateId    String
  authorId       String   // admin/recruiter who wrote the note
  note           String
  organizationId String?
  createdAt      DateTime @default(now())

  candidate      Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  author         User         @relation(fields: [authorId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([organizationId])
}

// ==================== SECURITY MODELS ====================

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SecurityAuditLog {
  id             String   @id @default(cuid())
  userId         String?
  organizationId String?
  action         String
  resourceType   String?
  resourceId     String?
  details        String?  // JSON string
  ipAddress      String?
  userAgent      String?
  status         String   @default("SUCCESS") // SUCCESS, FAILURE, BLOCKED
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([action, createdAt])
}

model Session {
  id                 String   @id @default(cuid())
  userId             String
  token              String   @unique
  ipAddress          String?
  userAgent          String?
  deviceFingerprint  String?
  isActive           Boolean  @default(true)
  expiresAt          DateTime
  lastActivityAt     DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([expiresAt])
}
